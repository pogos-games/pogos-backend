{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps",
  "sourceRoot": "apps/pogos-core/src",
  "projects": {
    "pogos-core": {
      "type": "application",
      "root": "apps/pogos-core",
      "entryFile": "main",
      "sourceRoot": "apps/pogos-core/src",
      "compilerOptions": {
        "tsConfigPath": "apps/pogos-core/tsconfig.app.json"
      }
    },
    "pogos-games": {
      "type": "application",
      "root": "apps/pogos-games",
      "entryFile": "main",
      "sourceRoot": "apps/pogos-games/src",
      "compilerOptions": {
        "tsConfigPath": "apps/pogos-games/tsconfig.app.json"
      }
    },
    "auth": {
      "type": "library",
      "root": "libs/tools-library",
      "entryFile": "index",
      "sourceRoot": "libs/tools-library/src",
      "compilerOptions": {
        "tsConfigPath": "libs/tools-library/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database-library",
      "entryFile": "index",
      "sourceRoot": "libs/database-library/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database-library/tsconfig.lib.json"
      }
    },
    "auth-library": {
      "type": "library",
      "root": "libs/auth-library",
      "entryFile": "index",
      "sourceRoot": "libs/auth-library/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth-library/tsconfig.lib.json"
      }
    }
  },
  "compilerOptions": {
    "webpack": true
  }
}